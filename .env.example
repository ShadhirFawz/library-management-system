# ================================
# Library Management System
# Docker Compose Environment
# ================================

# Shared JWT Secret
# IMPORTANT: This must be the same across all services
# Generate a secure random string for production
# Example: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# MongoDB Configuration
# For docker-compose, the services will use the 'mongo' service name
# No need to change this unless using external MongoDB
# MONGO_HOST=mongo
# MONGO_PORT=27017

# Optional: Set to production for production deployment
# NODE_ENV=development
