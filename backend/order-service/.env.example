# ─── Server ──────────────────────────────────────────────────
PORT=5003

# ─── MongoDB ─────────────────────────────────────────────────
# For local development:
#   MONGO_URI=mongodb://localhost:27017/order-service-db
# For Docker (using the library-mongo container):
#   MONGO_URI=mongodb://library-mongo:27017/order-service-db
MONGO_URI=mongodb://localhost:27017/order-service-db

# ─── JWT ─────────────────────────────────────────────────────
# Must match the secret used by the User Service when issuing tokens
JWT_SECRET=your_jwt_secret_here

# ─── Inter-service URLs ───────────────────────────────────────
# User Management Service base URL
USER_SERVICE_URL=http://localhost:5001

# Book Catalog Service base URL
BOOK_SERVICE_URL=http://localhost:5002

# ─── Business Rules ──────────────────────────────────────────
# Default borrow duration in days when User Service does not return one
DEFAULT_BORROW_DAYS=14

# Default fine per overdue day (in currency units) when membership plan
# does not specify one
DEFAULT_FINE_PER_DAY=0.50
