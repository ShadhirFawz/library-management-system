# ================================
# Book Catalog Service Configuration
# ================================

# Server Configuration
PORT=5002

# Database Configuration
# For local development:
MONGO_URI=mongodb://localhost:27017/book-catalog-db

# For Docker (using the library-mongo container):
# MONGO_URI=mongodb://library-mongo:27017/book-catalog-db

# For MongoDB Atlas (production):
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# Authentication
# Must match the secret used by User Service
# Generate a secure random string for production
# Example: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS Configuration (optional)
# CORS_ORIGIN=http://localhost:8080,http://localhost:3000

# Rate Limiting (optional)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# Environment
# NODE_ENV=development
