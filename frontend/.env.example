# ================================
# Frontend Environment Configuration
# ================================
# Copy this file to .env.local and update the values

# Microservice URLs
# These should point to your backend services
# For local development:
VITE_USER_SERVICE_URL=http://localhost:5001
VITE_BOOK_CATALOG_URL=http://localhost:5002
VITE_ORDER_SERVICE_URL=http://localhost:5003
VITE_HELP_SERVICE_URL=http://localhost:5004

# Legacy API Base URL (used by AuthContext)
# Should point to the User Service
VITE_API_BASE_URL=http://localhost:5001

# For production, use your deployed URLs:
# VITE_USER_SERVICE_URL=https://api.yourdomain.com/user-service
# VITE_BOOK_CATALOG_URL=https://api.yourdomain.com/book-catalog
# VITE_ORDER_SERVICE_URL=https://api.yourdomain.com/order-service
# VITE_HELP_SERVICE_URL=https://api.yourdomain.com/help-service
# VITE_API_BASE_URL=https://api.yourdomain.com/user-service

# Optional: API timeout in milliseconds
VITE_API_TIMEOUT=30000

# Optional: Debug mode
VITE_DEBUG=false
